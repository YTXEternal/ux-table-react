{
  "name": "ux-table-react",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/ux-table-react.umd.js",
  "module": "./dist/ux-table-react.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ux-table-react.es.js",
      "require": "./dist/ux-table-react.umd.js"
    },
    "./style.css": "./dist/ux-table-react.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --mode development",
    "build": "tsc -b && vite build --mode production",
    "build:test": "tsc -b && vite build --mode test",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest --passWithNoTests",
    "test:e2e": "cypress open",
    "test:e2e:run": "cypress run",
    "commit": "git-cz",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "tsc --noEmit"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@unocss/preset-attributify": "^66.6.7",
    "@unocss/preset-icons": "^66.6.7",
    "@unocss/preset-uno": "^66.6.7",
    "@vitejs/plugin-react": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "commitizen": "^4.3.1",
    "cypress": "^15.12.0",
    "cz-git": "^1.12.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "unocss": "^66.6.7",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vue": "^3.5.30"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23"
  }
}
