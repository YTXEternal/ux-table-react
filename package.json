{
  "name": "ux-table-react",
  "private": false,
  "version": "1.2.0",
  "description": "一个高性能的 React 表格组件，支持虚拟滚动、单元格编辑、列排序和固定列等高级特性，基于 UnoCSS 打造。",
  "keywords": [
    "react",
    "table",
    "component",
    "datagrid",
    "unocss",
    "typescript",
    "ui",
    "virtual-scroll",
    "editable",
    "fixed-columns",
    "high-performance"
  ],
  "author": "ux_rcl",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "sideEffects": [
    "*.css",
    "**/*.css",
    "src/plugins/**/*"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YTXEternal/ux-table-react"
  },
  "bugs": {
    "url": "https://github.com/YTXEternal/ux-table-react/issues"
  },
  "homepage": "https://ytxeternal.github.io/ux-table-react",
  "type": "module",
  "main": "./dist/ux-table-react.umd.js",
  "module": "./dist/ux-table-react.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/ux-table-react.es.js",
      "require": "./dist/ux-table-react.umd.js"
    },
    "./style.css": "./dist/ux-table-react.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --mode development",
    "build": "tsc -b && vite build --mode production",
    "build:test": "tsc -b && vite build --mode test",
    "build:example": "tsc -b && vite build --config vite.build.config.ts --mode production",
    "build:dev": "tsc -b && vite build --config vite.build.config.ts --mode development",
    "preview:example": "vite preview --config vite.build.config.ts --mode production",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest --passWithNoTests",
    "test:e2e": "start-server-and-test dev http://localhost:5173 'cypress open'",
    "test:e2e:run": "pnpm test:e2e:chrome",
    "test:e2e:chrome": "start-server-and-test dev http://localhost:5173 'cypress run --browser chrome'",
    "test:e2e:edge": "start-server-and-test dev http://localhost:5173 'cypress run --browser edge'",
    "test:e2e:firefox": "start-server-and-test dev http://localhost:5173 'cypress run --browser firefox'",
    "test:e2e:all": "pnpm test:e2e:firefox && pnpm test:e2e:chrome && pnpm test:e2e:edge",
    "commit": "tsx scripts/commit.ts",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "tsc --noEmit"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@unocss/preset-attributify": "^66.6.7",
    "@unocss/preset-icons": "^66.6.7",
    "@unocss/preset-uno": "^66.6.7",
    "@unocss/transformer-directives": "^66.6.7",
    "@vitejs/plugin-react": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "commitizen": "^4.3.1",
    "cypress": "^15.12.0",
    "cz-git": "^1.12.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "start-server-and-test": "^2.1.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "unocss": "^66.6.7",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vue": "^3.5.30"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23"
  }
}
